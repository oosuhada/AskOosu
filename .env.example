GITHUB_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional provider mode: openai (default), xai, or groq
ASKOOSU_AI_PROVIDER=openai

# Optional Grok/xAI mode
# ASKOOSU_AI_PROVIDER=xai
XAI_API_KEY=
XAI_MODEL=grok-4
XAI_API_MODE=responses
XAI_BASE_URL=https://api.x.ai/v1

# Optional Groq key pool mode
# Format: label:key,label:key or just key,key
# ASKOOSU_AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_KEY_FAILURE_THRESHOLD=3
GROQ_KEY_COOLDOWN_MS=900000
GROQ_KEY_QUOTA_COOLDOWN_MS=3600000

# Optional Google Vertex AI fallback/provider mode
# ASKOOSU_AI_PROVIDER=google_vertex
GOOGLE_VERTEX_API_KEY=
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=

# Optional Notion RAG source
NOTION_API_KEY=
# Preferred: parent AskOosu Wiki page. If parent recursion misses child pages,
# leave NOTION_PAGE_ID empty and set ASKOOSU_NOTION_PAGE_IDS to KO,EN page IDs.
NOTION_PAGE_ID=
NOTION_VERSION=2026-03-11
ASKOOSU_NOTION_PAGE_IDS=
ASKOOSU_NOTION_DATABASE_IDS=
ASKOOSU_NOTION_DATA_SOURCE_IDS=
ASKOOSU_RAG_STORE=memory
ASKOOSU_RAG_AUTO_SYNC=true
ASKOOSU_RAG_RETRIEVAL=lexical
ASKOOSU_RAG_TOP_K=5
ASKOOSU_RAG_CACHE_TTL_MS=600000
ASKOOSU_RAG_CHUNK_SIZE=1200
ASKOOSU_RAG_CHUNK_OVERLAP=180
RAG_SYNC_SECRET=
ASKOOSU_RAG_ADMIN_TOKEN=
ASKOOSU_WIKI_VERSION=v10
ASKOOSU_ANSWER_CACHE_TTL_HOURS=24
ASKOOSU_EMBEDDING_MODEL=text-embedding-3-small
ASKOOSU_EMBEDDING_DIMENSIONS=1536
ASKOOSU_EMBEDDING_PARALLELISM=2
DATABASE_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
