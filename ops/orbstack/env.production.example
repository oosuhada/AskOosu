POSTGRES_USER=askoosu
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_DB=askoosu
DATABASE_URL=postgres://askoosu:replace_with_a_strong_password@postgres:5432/askoosu

NEXT_PUBLIC_APP_URL=https://oosu.dev

ASKOOSU_AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_KEY_FAILURE_THRESHOLD=3
GROQ_KEY_COOLDOWN_MS=900000
GROQ_KEY_QUOTA_COOLDOWN_MS=3600000

GOOGLE_VERTEX_API_KEY=
GOOGLE_VERTEX_PROJECT=
GOOGLE_CLOUD_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_AI_ENABLED=false
GOOGLE_AI_MAX_CALLS_PER_DAY=100
GOOGLE_AI_DAILY_BUDGET_USD=1.00
GOOGLE_AI_COOLDOWN_MS=60000

NOTION_API_KEY=
# Preferred: parent AskOosu Wiki page. If parent recursion misses child pages,
# leave NOTION_PAGE_ID empty and set ASKOOSU_NOTION_PAGE_IDS to KO,EN page IDs.
NOTION_PAGE_ID=
ASKOOSU_NOTION_PAGE_IDS=
ASKOOSU_NOTION_KO_PAGE_IDS=
ASKOOSU_NOTION_EN_PAGE_IDS=
NOTION_VERSION=2026-03-11

ASKOOSU_RAG_STORE=postgres
ASKOOSU_RAG_AUTO_SYNC=false
ASKOOSU_RAG_RETRIEVAL=lexical
ASKOOSU_RAG_TOP_K=5
ASKOOSU_RAG_CACHE_TTL_MS=600000
ASKOOSU_RAG_SEARCH_CACHE_TTL_MS=300000
ASKOOSU_RAG_CHUNK_SIZE=1200
ASKOOSU_RAG_CHUNK_OVERLAP=180
ASKOOSU_RAG_SYNC_LOCK_TTL_SECONDS=300
RAG_SYNC_SECRET=
ASKOOSU_RAG_ADMIN_TOKEN=
ASKOOSU_WIKI_VERSION=v10
ASKOOSU_ANSWER_CACHE_TTL_HOURS=24
ASKOOSU_CHAT_MAX_REQUEST_BYTES=32768

ASKOOSU_EMBEDDING_MODEL=text-embedding-3-small
ASKOOSU_EMBEDDING_DIMENSIONS=1536
ASKOOSU_EMBEDDING_PARALLELISM=2
